generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model appointment {
  appointment_id   BigInt           @id @default(autoincrement())
  appointment_no   String           @unique @db.VarChar(30)
  patient_id       BigInt
  doctor_id        BigInt
  branch_id        String           @db.VarChar(10)
  schedule_id      BigInt?
  appointment_ts   DateTime         @db.Timestamptz(6)
  status           String           @db.VarChar(20)
  reason_for_visit String?
  created_by       BigInt?
  created_at       DateTime         @default(now()) @db.Timestamptz(6)
  updated_at       DateTime         @default(now()) @db.Timestamptz(6)
  employee         employee?        @relation(fields: [created_by], references: [employee_id], onDelete: NoAction, onUpdate: NoAction)
  doctor_profile   doctor_profile   @relation(fields: [doctor_id], references: [employee_id], onDelete: NoAction, onUpdate: NoAction)
  patient          patient          @relation(fields: [patient_id], references: [patient_id], onDelete: NoAction, onUpdate: NoAction)
  doctor_schedule  doctor_schedule? @relation(fields: [schedule_id], references: [schedule_id], onDelete: NoAction, onUpdate: NoAction)
  encounter        encounter?

  @@index([patient_id], map: "idx_appointment_patient")
}

model audit_log {
  audit_log_id BigInt    @id @default(autoincrement())
  action_type  String?   @db.VarChar(50)
  patient_id   BigInt?
  event_ts     DateTime? @default(now()) @db.Timestamptz(6)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model branch {
  branch_id          String    @id @default(dbgenerated("nextval('branch_branch_id_seq'::regclass)")) @db.VarChar(10)
  branch_name        String    @db.VarChar(150)
  branch_type        String    @db.VarChar(20)
  email              String?   @db.VarChar(150)
  address            String?   @db.VarChar(200)
  city               String?   @db.VarChar(100)
  state_name         String?   @db.VarChar(100)
  branch_address     String?
  branch_code        String?   @db.VarChar(20)
  emergency_number   String?   @db.VarChar(100)
  contact_number     String?   @db.VarChar(15)
  country            String?   @db.VarChar(50)
  pincode            String?   @db.VarChar(10)
  license_number     String?   @db.VarChar(50)
  total_beds         Int?
  branch_status      String?   @default("Active") @db.VarChar(20)
  created_by         String?   @db.VarChar(20)
  date_of_establish  DateTime? @db.Date
  medical_services   String?   @db.VarChar(100)
  icu_beds           Int?
  consulation_rooms  Int?
  operation_theaters Int?
  id                 BigInt    @default(autoincrement())
  hospital_id        String?   @db.VarChar(20)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model doctor_profile {
  employee_id          BigInt            @id
  specialization       String            @db.VarChar(100)
  qualification        String?           @db.VarChar(150)
  license_no           String?           @unique @db.VarChar(50)
  consultation_minutes Int               @default(15)
  appointment          appointment[]
  employee             employee          @relation(fields: [employee_id], references: [employee_id], onDelete: NoAction, onUpdate: NoAction)
  doctor_schedule      doctor_schedule[]
  encounter            encounter[]
  prescription         prescription[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model doctor_schedule {
  schedule_id      BigInt         @id @default(autoincrement())
  doctor_id        BigInt
  branch_id        String         @db.VarChar(10)
  slot_start       DateTime       @db.Timestamptz(6)
  slot_end         DateTime       @db.Timestamptz(6)
  slot_status      String         @default("OPEN") @db.VarChar(20)
  max_appointments Int            @default(1)
  created_at       DateTime       @default(now()) @db.Timestamptz(6)
  appointment      appointment[]
  doctor_profile   doctor_profile @relation(fields: [doctor_id], references: [employee_id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model employee {
  employee_id          BigInt                @id @default(autoincrement())
  employee_code        String                @unique @db.VarChar(30)
  full_name            String                @db.VarChar(150)
  gender               String?               @db.VarChar(20)
  dob                  DateTime?             @db.Date
  phone                String?               @db.VarChar(30)
  email                String?               @db.VarChar(150)
  hire_date            DateTime?             @db.Date
  status               String                @default("ACTIVE") @db.VarChar(20)
  created_at           DateTime              @default(now()) @db.Timestamptz(6)
  updated_at           DateTime              @default(now()) @db.Timestamptz(6)
  appointment          appointment[]
  doctor_profile       doctor_profile?
  employee_branch      employee_branch[]
  lab_order            lab_order[]
  lab_tech_profile     lab_tech_profile?
  receptionist_profile receptionist_profile?
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model employee_branch {
  employee_branch_id BigInt    @id @default(autoincrement())
  employee_id        BigInt
  branch_id          String    @db.VarChar(10)
  role_code          String    @db.VarChar(30)
  department_name    String?   @db.VarChar(100)
  start_date         DateTime  @default(dbgenerated("CURRENT_DATE")) @db.Date
  end_date           DateTime? @db.Date
  is_primary_branch  Boolean   @default(false)
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  employee           employee  @relation(fields: [employee_id], references: [employee_id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([employee_id, branch_id, role_code, start_date])
}

model encounter {
  encounter_id        BigInt          @id @default(autoincrement())
  encounter_no        String          @unique @db.VarChar(30)
  patient_id          BigInt
  branch_id           String          @db.VarChar(10)
  appointment_id      BigInt?         @unique
  attending_doctor_id BigInt?
  encounter_ts        DateTime        @default(now()) @db.Timestamptz(6)
  encounter_type      String          @default("OPD") @db.VarChar(20)
  status              String          @default("OPEN") @db.VarChar(20)
  notes               String?
  created_at          DateTime        @default(now()) @db.Timestamptz(6)
  appointment         appointment?    @relation(fields: [appointment_id], references: [appointment_id], onDelete: NoAction, onUpdate: NoAction)
  doctor_profile      doctor_profile? @relation(fields: [attending_doctor_id], references: [employee_id], onDelete: NoAction, onUpdate: NoAction)
  patient             patient         @relation(fields: [patient_id], references: [patient_id], onDelete: NoAction, onUpdate: NoAction)
  lab_order           lab_order[]
  prescription        prescription[]

  @@index([patient_id], map: "idx_encounter_patient")
}

model global_master {
  role_id          String?   @db.VarChar(20)
  role_type        String?   @db.VarChar(50)
  created_by       String?   @db.VarChar(20)
  name             String?   @db.VarChar(100)
  gender           String?   @db.VarChar(10)
  mobile           String?   @db.VarChar(15)
  email            String?   @db.VarChar(100)
  username         String?   @db.VarChar(50)
  password         String?   @db.VarChar(255)
  status           Int?      @default(0) @db.SmallInt
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  hospital_type    String?   @db.VarChar(50)
  website          String?   @db.VarChar(200)
  city             String?   @db.VarChar(100)
  state            String?   @db.VarChar(100)
  country          String?   @db.VarChar(100)
  pincode          String?   @db.VarChar(10)
  branch           String?   @db.VarChar(50)
  hospital_name    String?   @db.VarChar(100)
  hospital_address String?   @db.VarChar(100)
  branch_id        String?   @db.VarChar(10)
  id               BigInt    @id @default(autoincrement())
  hospital_id      String    @unique(map: "uq_hospital_id") @default(dbgenerated("nextval('global_master_hospital_id_seq'::regclass)")) @db.VarChar(20)
}

model lab_order {
  lab_order_id BigInt       @id @default(autoincrement())
  encounter_id BigInt
  ordered_by   BigInt
  branch_id    String       @db.VarChar(10)
  order_status String       @default("ORDERED") @db.VarChar(20)
  ordered_at   DateTime     @default(now()) @db.Timestamptz(6)
  notes        String?
  encounter    encounter    @relation(fields: [encounter_id], references: [encounter_id], onDelete: Cascade, onUpdate: NoAction)
  employee     employee     @relation(fields: [ordered_by], references: [employee_id], onDelete: NoAction, onUpdate: NoAction)
  lab_result   lab_result[]

  @@index([encounter_id], map: "idx_lab_order")
}

model lab_result {
  lab_result_id BigInt    @id @default(autoincrement())
  lab_order_id  BigInt
  test_code     String    @db.VarChar(50)
  test_name     String    @db.VarChar(150)
  result_value  String?   @db.VarChar(150)
  unit_name     String?   @db.VarChar(50)
  normal_range  String?   @db.VarChar(100)
  result_status String    @default("FINAL") @db.VarChar(20)
  resulted_at   DateTime? @db.Timestamptz(6)
  lab_order     lab_order @relation(fields: [lab_order_id], references: [lab_order_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([lab_order_id, test_code])
}

model lab_tech_profile {
  employee_id      BigInt   @id
  certification_no String?  @db.VarChar(50)
  skill_notes      String?
  employee         employee @relation(fields: [employee_id], references: [employee_id], onDelete: NoAction, onUpdate: NoAction)
}

model patient {
  patient_id         BigInt               @id @default(autoincrement())
  patient_no         String               @unique @db.VarChar(30)
  full_name          String               @db.VarChar(150)
  dob                DateTime?            @db.Date
  gender             String?              @db.VarChar(20)
  blood_group        String?              @db.VarChar(10)
  emergency_contact  String?              @db.VarChar(150)
  emergency_phone    String?              @db.VarChar(30)
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime             @default(now()) @db.Timestamptz(6)
  appointment        appointment[]
  encounter          encounter[]
  patient_contact    patient_contact[]
  patient_identifier patient_identifier[]
}

model patient_contact {
  patient_contact_id BigInt   @id @default(autoincrement())
  patient_id         BigInt
  contact_type       String   @db.VarChar(20)
  contact_value      String   @db.VarChar(200)
  is_primary         Boolean  @default(false)
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  patient            patient  @relation(fields: [patient_id], references: [patient_id], onDelete: Cascade, onUpdate: NoAction)
}

model patient_identifier {
  patient_identifier_id BigInt    @id @default(autoincrement())
  patient_id            BigInt
  id_type               String    @db.VarChar(30)
  id_value              String    @db.VarChar(100)
  issued_by             String?   @db.VarChar(100)
  valid_from            DateTime? @db.Date
  valid_to              DateTime? @db.Date
  patient               patient   @relation(fields: [patient_id], references: [patient_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([id_type, id_value])
}

model prescription {
  prescription_id   BigInt              @id @default(autoincrement())
  encounter_id      BigInt
  prescribed_by     BigInt
  prescribed_at     DateTime            @default(now()) @db.Timestamptz(6)
  notes             String?
  encounter         encounter           @relation(fields: [encounter_id], references: [encounter_id], onDelete: Cascade, onUpdate: NoAction)
  doctor_profile    doctor_profile      @relation(fields: [prescribed_by], references: [employee_id], onDelete: NoAction, onUpdate: NoAction)
  prescription_item prescription_item[]
}

model prescription_item {
  prescription_item_id BigInt       @id @default(autoincrement())
  prescription_id      BigInt
  medicine_name        String       @db.VarChar(150)
  dose                 String       @db.VarChar(100)
  frequency_text       String?      @db.VarChar(100)
  duration_days        Int?
  instructions         String?
  prescription         prescription @relation(fields: [prescription_id], references: [prescription_id], onDelete: Cascade, onUpdate: NoAction)
}

model receptionist_profile {
  employee_id BigInt   @id
  remarks     String?
  employee    employee @relation(fields: [employee_id], references: [employee_id], onDelete: NoAction, onUpdate: NoAction)
}

