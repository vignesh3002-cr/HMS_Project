generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model appointment_history {
  appointment_id       String             @unique(map: "uq_appointment_id") @db.VarChar(20)
  patient_id           String             @db.VarChar(20)
  doctor_name          String             @db.VarChar(100)
  department           String?            @db.VarChar(100)
  appointment_date     DateTime           @db.Date
  appointment_time     DateTime           @db.Time(6)
  token_number         Int?
  booking_source       String?            @db.VarChar(30)
  appointment_status   String?            @db.VarChar(30)
  chief_complaint      String?
  symptoms             String?
  lab_test_details     String?
  scan_details         String?
  consultation_fee     Decimal?           @db.Decimal(10, 2)
  bill_amount          Decimal?           @db.Decimal(10, 2)
  payment_status       String?            @db.VarChar(20)
  payment_mode         String?            @db.VarChar(30)
  checkin_time         DateTime?          @db.Timestamp(6)
  checkout_time        DateTime?          @db.Timestamp(6)
  id                   BigInt             @id @default(autoincrement())
  branch_id            String?            @db.VarChar(10)
  department_id        String?            @db.VarChar(20)
  user_id              String?            @db.VarChar(20)
  assigned_doctor      String?            @db.VarChar(50)
  reason_for_visit     String?            @db.VarChar(500)
  referred_by          String?            @db.VarChar(100)
  employee_id          String?            @db.VarChar(20)
  created_by           String?            @db.VarChar
  created_at           DateTime?          @default(now()) @db.Timestamp(6)
  status               String?            @db.VarChar
  schedule_id          BigInt?
  diagnosis_id         String?            @db.VarChar(20)
  diagnosis_text       String?
  prescription_details String?
  employees            employees?         @relation(fields: [employee_id], references: [employee_id], onDelete: Cascade)
  doctor_schedule      doctor_schedule?   @relation(fields: [schedule_id], references: [schedule_id], onDelete: NoAction, onUpdate: NoAction)
  branch               branch?            @relation(fields: [branch_id], references: [branch_id], onDelete: Cascade, map: "fk_appointment_branch")
  department_master    department_master? @relation(fields: [department_id], references: [department_id], onDelete: Cascade, map: "fk_appointment_department")
  diagnosis            diagnosis?         @relation(fields: [diagnosis_id], references: [diagnosis_id], onDelete: Cascade, map: "fk_appointment_diagnosis")
  patient_bio_data     patient_bio_data   @relation(fields: [patient_id], references: [patient_id], onDelete: Cascade, map: "fk_appointment_patient")
  user_table           user_table?        @relation(fields: [user_id], references: [user_id], onDelete: Cascade, map: "fk_appointment_user")
  encounter            encounter?
  lab_history          lab_history[]
  patient_history      patient_history[]
  pharmacy             pharmacy[]
  prescription         prescription[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model branch {
  branch_id           String                @unique(map: "uq_branch_branch_id") @default(dbgenerated("nextval('branch_branch_id_seq'::regclass)")) @db.VarChar(10)
  branch_type         String                @db.VarChar(20)
  district            String?               @db.VarChar(100)
  state_name          String?               @db.VarChar(100)
  branch_code         String?               @db.VarChar(20)
  country             String?               @db.VarChar(50)
  total_beds          Int?
  branch_status       String?               @default("Active") @db.VarChar(20)
  date_of_establish   DateTime?             @db.Date
  medical_services    String?               @db.VarChar(100)
  id                  BigInt                @id @default(autoincrement())
  branch_name         String?               @db.VarChar(50)
  branch_area         String?               @db.VarChar(50)
  address             String?               @db.VarChar(500)
  emergency_no        String?               @db.VarChar(20)
  hospital_id         String?               @db.VarChar(20)
  branch_license_no   String?               @db.VarChar(20)
  website_address     String?               @db.VarChar(100)
  pan_no              String?               @db.VarChar(20)
  gst_no              String?               @db.VarChar(20)
  total_no_emp        String?               @db.VarChar(500)
  branch_email        String?               @db.VarChar(100)
  fax_no              String?               @db.VarChar(20)
  branch_pincode      Int?
  branch_photo_url    String?               @db.VarChar
  appointment_history appointment_history[]
  hospital            hospital?             @relation(fields: [hospital_id], references: [hospital_id], onDelete: Cascade, map: "fk_branch_hospital")
  chemotherapy_master chemotherapy_master[]
  doctor_schedule     doctor_schedule[]
  employees           employees[]
  encounter           encounter[]
  lab_history         lab_history[]
  patient_bio_data    patient_bio_data[]
  patient_history     patient_history[]
  pharmacy            pharmacy[]
  prescription        prescription[]
  user_branch_mapping user_branch_mapping[]
  user_log            user_log[]
  user_table          user_table[]
}

